# ------------------------------------------------------------------
# My Spot Café — environment variables
#
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Restart `npm run dev` after editing.
# ------------------------------------------------------------------

# Admin panel credentials (used by /admin/login).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# A long random string used to sign the admin session cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=9f7c2a8d4b6e1f3a5c7d9e2f4a6b8c1d3e5f7a9b2c4d6e8f1a3b5c7d9e2f4a

# Public site URL — used for canonical URLs, Open Graph, sitemap & robots.
NEXT_PUBLIC_SITE_URL=https://my-spot-caffe-kappa.vercel.app

# ------------------------------------------------------------------
# PostgreSQL (REQUIRED on Vercel for persistent admin saves)
#
# Vercel Dashboard → Project → Storage → Create Database → Postgres
# Connect to project → copy DATABASE_URL → redeploy → run migrations:
#   npx prisma migrate deploy
#   npx prisma db seed   (first deploy only)
#
# For Vercel Postgres + Prisma, append to DATABASE_URL if using pooling:
#   ?sslmode=require&pgbouncer=true
# ------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# ------------------------------------------------------------------
# Optional fallbacks (only if DATABASE_URL is not set)
# ------------------------------------------------------------------

# Upstash Redis — KV_REST_API_URL + KV_REST_API_TOKEN (or UPSTASH_REDIS_REST_*)
# Vercel Blob — BLOB_READ_WRITE_TOKEN (also used for image uploads on Vercel)
