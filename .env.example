# ------------------------------------------------------------------
# My Spot Café — environment variables
#
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Restart `npm run dev` after editing.
# ------------------------------------------------------------------

# Admin panel credentials (used by /admin/login).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# A long random string used to sign the admin session cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=9f7c2a8d4b6e1f3a5c7d9e2f4a6b8c1d3e5f7a9b2c4d6e8f1a3b5c7d9e2f4a

# Public site URL — used for canonical URLs, Open Graph, sitemap & robots.
# Should be your production origin without a trailing slash.
NEXT_PUBLIC_SITE_URL=https://my-spot-caffe-kappa.vercel.app

# ------------------------------------------------------------------
# Vercel production storage (required for admin saves to persist)
#
# On Vercel, the server filesystem is temporary. Connect ONE of these
# in Vercel Dashboard → your project → Storage, then redeploy:
#
# Option A — Upstash Redis (recommended, free tier available)
#   Adds: UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
#   (Legacy KV uses KV_REST_API_URL + KV_REST_API_TOKEN instead)
#
# Option B — Vercel Blob
#   Adds: BLOB_READ_WRITE_TOKEN
# ------------------------------------------------------------------
